# Copy this file to .env.local and paste your real key there.
#   cp .env.example .env.local
#
# .env.local is gitignored — it stays on your machine only. In production you set
# the SAME variable in Vercel (vercel env add KOLLA_API_KEY), never in any file.
#
# Leave KOLLA_API_KEY empty to run in mock mode (fake, PHI-free rosters).
# Paste your Kolla Unify API key to pull REAL data locally.
KOLLA_API_KEY=
